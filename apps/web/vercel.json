{
  "redirects": [
    {
      "source": "/((?!\\.well-known|api|wise-web-hook).+)",
      "has": [{ "type": "host", "value": "soundbridge.live" }],
      "destination": "https://www.soundbridge.live/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/moderate-content",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/process-pending-notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/expire-grace-periods",
      "schedule": "0 0 * * *"
    }
  ]
}
